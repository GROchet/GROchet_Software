#include <Dynamixel2Arduino.h>

#define DXL_SERIAL   Serial1
#define DXL_DIR_PIN  -1

#define OPEN_POS  1000
#define CLOSED_POS 4000

Dynamixel2Arduino dxl(DXL_SERIAL, DXL_DIR_PIN);
uint8_t id = 102;
uint8_t strength = 5;
bool PinceFermee = false;

// Function prototypes
void fermerPince();
void ouvrirPince();
void modeTorque();
void modePosition();
int detecterToutou();

void setup() {
    Serial.begin(115200);
    delay(2000);

    dxl.begin(57600);
    dxl.setPortProtocolVersion(2.0);

    // For finding ID of your DYNAMIXEL, use this code.
    for (uint8_t i = 0; i < 253; i++) {
        if (dxl.ping(i)) {
            Serial.print("Found Dynamixel ID: ");
            Serial.println(i);
            id = i;
        }
    }

    if (!dxl.ping(id)) {
        Serial.println("No Dynamixel found. Reality is disappointing.");
        while (1); // Stop everything
    }

    Serial.println("Dynamixel detected. Miracles happen.");
    modeTorque();
    Serial.println("Set to torque control mode.");
}

void loop() {
    ouvrirPince();
    Serial.println("Pince ouverte");
    delay(2000);

    fermerPince();
    Serial.println("Pince fermée. Verification de la presence du toutou...");
    delay(100); // ish

    // Wait until the "toutou" is detected
    int status = 0;
    while (status == 0) {
        status = detecterToutou();
        delay(100);
    }

    if (status == 1) {
        Serial.println("Toutou attrapé !");
    } else if (status == 2) {
        Serial.println("Pince fermée sans toutou.");
        ouvrirPince();
    }

    delay(3000); // Keep the "toutou" grabbed for 3 seconds
}

void fermerPince() {
    // Serrer toutou
    modeTorque();
    dxl.writeControlTableItem(ControlTableItem::GOAL_CURRENT, id, strength);
    PinceFermee = true;
}

void ouvrirPince() {

    // Aller en position ouverte
    modePosition();
    dxl.setGoalPosition(id, OPEN_POS); // Use OPEN_POS
}

void modeTorque() {
    dxl.torqueOff(id);
    dxl.setOperatingMode(id, OP_CURRENT);
    dxl.torqueOn(id);
}

void modePosition() {
    dxl.torqueOff(id);
    dxl.setOperatingMode(id, OP_EXTENDED_POSITION);
    dxl.torqueOn(id);
}

int detecterToutou() {
    // Each tick, check
    int32_t present_position = dxl.getPresentPosition(id);
    int32_t present_velocity = dxl.getPresentVelocity(id);

    Serial.print("Position: ");
    Serial.print(present_position);
    Serial.print(" Velocity: ");
    Serial.println(present_velocity);

    // Check if velocity is near zero (toutou caught)
    if (present_position > CLOSED_POS - 5) {
        // ouvrirPince();
        return 2; // Pince fermée sans toutou
    } else if (abs(present_velocity) < 5) {
        return 1; // Toutou attrapé
    } else {
        return 0; // Pas de toutou
    }
}

